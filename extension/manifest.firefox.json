{
  "manifest_version": 2,
  "name": "Email to Notion",
  "version": "1.0.7",
  "description": "Export Gmail emails to a Notion database with one click.",
  "permissions": [
    "storage",
    "identity",
    "tabs",
    "https://mail.google.com/*",
    "https://api.notion.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_title": "Email to Notion",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": ["popup/export-popup.html"],
  "browser_specific_settings": {
    "gecko": {
      "id": "email-to-notion@extension",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
